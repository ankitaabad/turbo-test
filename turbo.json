{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "tsconfig.base.json",
    "biome.json",
    "pnpm-workspace.yaml",
    ".github/workflows/**",
    ".github/actions/**"
  ],
  "tasks": {
    "build": {
      "outputs": ["dist/**"],
      "inputs": ["**", "!**/*.md"]
    },
    "lint": {
      "inputs": ["**", "!**/*.md"]
    },
    "typecheck": {
      "inputs": ["**", "!**/*.md"]
    }
  }
}
